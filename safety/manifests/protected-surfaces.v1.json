{
  "schema_version": "1.0.0",
  "suite_id": "phase-1-default",
  "test_id": "phase-1-safety",
  "surfaces": [
    {
      "surface_id": "worktree-tracked",
      "surface_domain": "worktree",
      "logical_ref": "repo:sentinel/worktree/tracked",
      "policy": "required",
      "adapter_id": "git-worktree-readonly-v1",
      "bounds": { "max_files": 4096, "max_bytes": 16777216, "timeout_ms": 5000 }
    },
    {
      "surface_id": "worktree-index",
      "surface_domain": "worktree",
      "logical_ref": "repo:sentinel/worktree/index",
      "policy": "required",
      "adapter_id": "git-index-readonly-v1",
      "bounds": { "max_files": 4096, "max_bytes": 16777216, "timeout_ms": 5000 }
    },
    {
      "surface_id": "named-home-zshrc",
      "surface_domain": "named-home",
      "logical_ref": "home:.zshrc",
      "policy": "required",
      "adapter_id": "go-lstat-file-v1",
      "bounds": { "max_files": 1, "max_bytes": 1048576, "timeout_ms": 1000 }
    },
    {
      "surface_id": "manager-mise-data",
      "surface_domain": "manager-root",
      "logical_ref": "home:sentinel/manager/mise-data",
      "policy": "required",
      "adapter_id": "go-bounded-tree-v1",
      "bounds": { "max_files": 2048, "max_bytes": 16777216, "timeout_ms": 5000 }
    },
    {
      "surface_id": "service-homebrew-nginx",
      "surface_domain": "service",
      "logical_ref": "profile:sentinel/service/homebrew-mxcl-nginx",
      "policy": "required",
      "adapter_id": "launchctl-print-service-v1",
      "bounds": { "max_files": 1, "max_bytes": 65536, "timeout_ms": 2000 }
    },
    {
      "surface_id": "named-target-system-shells",
      "surface_domain": "named-target",
      "logical_ref": "profile:sentinel/named-target/system-shells",
      "policy": "required",
      "adapter_id": "go-system-shells-file-v1",
      "bounds": { "max_files": 1, "max_bytes": 1048576, "timeout_ms": 1000 }
    }
  ]
}
