# 字体设置
font-family = Maple Mono Normal NF CN
font-size = 13
font-thicken = true
font-thicken-strength = 1
adjust-cell-height = 1

# Catppuccin Mocha 主题
theme = Catppuccin Mocha
background = #1e1e2e
foreground = #cdd6f4
selection-background = #585b70
selection-foreground = #cdd6f4
cursor-color = #f5e0dc
cursor-text = #1e1e2e
palette = 0=#45475a
palette = 1=#f38ba8
palette = 2=#a6e3a1
palette = 3=#f9e2af
palette = 4=#89b4fa
palette = 5=#f5c2e7
palette = 6=#94e2d5
palette = 7=#bac2de
palette = 8=#585b70
palette = 9=#f38ba8
palette = 10=#a6e3a1
palette = 11=#f9e2af
palette = 12=#89b4fa
palette = 13=#f5c2e7
palette = 14=#94e2d5
palette = 15=#a6adc8

# 背景不透明度（毛玻璃效果）
background-opacity = 0.65
# 背景模糊半径
background-blur = 16

# 光标
cursor-style = bar
cursor-style-blink = true

# 窗口
window-padding-x = 12
window-padding-y = 6
window-width = 115
window-height = 38
window-save-state = always
window-step-resize = true
window-colorspace = display-p3
scrollback-limit = 100000

# macOS 相关
macos-icon = custom-style
macos-icon-frame = aluminum
macos-icon-ghost-color = #FFFFFF
macos-icon-screen-color = #4facfe,#00f2fe
macos-titlebar-proxy-icon = hidden
macos-auto-secure-input = true
macos-secure-input-indication = true
title = " "

# 铃声
bell-features = no-attention,no-title

# Shell 集成
shell-integration-features = sudo

# 快捷键
keybind = shift+enter=text:\x1b\r

# 自动更新
auto-update = off
